import java.util.*;
class Node
{
    int data;
    Node next;
    Node(int data,Node next1)
    {
        this.data=data;
        this.next=next1;
    }
    Node (int data)
    {
        this.data=data;
    }
}
class Main {
    public static void main(String[] args) {
        Node head = new Node(7);
        Node temp=head;
        
        for(int i=0;i<5;i++)
        {
            Node mover=new Node(i);
            temp.next=mover;
            temp=mover;
        }
        Node temp1=head;
        while(temp1.next!=null)
        {
            System.out.print(temp1.data+" ");
            temp1=temp1.next;
        }
    }
}
