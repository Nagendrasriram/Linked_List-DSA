
class Node {
    int data;
    Node next;

    Node(int val) {
        data = val;
        next = null;
    }
}
class Main {
    public static void main(String[] args) {
        Node head = new Node(10);
        head.next = new Node(20);
        head.next.next = new Node(30);
        System.out.print(searchValue(head,20));
    }
    public static boolean searchValue(Node head, int key){
        Node temp=head;
        while(temp!=null)
        {
            if(temp.data==key)
            {
                return true;
            }
            temp=temp.next;
        }
        return false;
    }
}
